# Copy this file to .env.local and fill in values for local development.
DRATA_API_KEY=
DRATA_REGION=us
DRATA_DEFAULT_VERSION=v2

# Optional: override all region-based routing.
# DRATA_BASE_URL=https://public-api.drata.com

# Optional: fetch the API key from a secret manager command.
# DRATA_API_KEY_CMD=op read op://vault/drata/api-key

# Optional: block mutating requests by default.
# DRATA_READ_ONLY=1
